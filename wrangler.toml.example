# Copy to `wrangler.toml` and adjust `name`, `account_id`, and (optionally)
# a `routes`/`workers_dev` block for your environment. The real `wrangler.toml`
# is gitignored so personal account details and routes are not committed.
#
# Docs: https://developers.cloudflare.com/workers/wrangler/configuration/

name = "nslookup"
main = "worker.js"
compatibility_date = "2025-01-01"

# Use workers.dev subdomain for quick testing:
workers_dev = true

# Or bind to your own route(s) — uncomment and edit:
# routes = [
#   { pattern = "nslookup.example.com/*", zone_name = "example.com" }
# ]

# Your Cloudflare account id (find it in the dashboard URL or via
# `npx wrangler whoami`):
# account_id = "0000000000000000000000000000000"
